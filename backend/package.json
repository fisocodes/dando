{
	"main": "dist/src/main",
	"scripts": {
		"build": "nest build",
		"start:dev": "nest start --watch",
		"start:prod": "node .",
		"migration:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/$npm_config_name -d src/database/database.datasource.ts",
