		"@nestjs/testing": "^11.1.27",
		"@react-email/ui": "^6.5.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.1",
		"ts-jest": "^29.4.11",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3"
